# Environment Configuration File
# Copy this file to .env and update with your actual values

# Database Configuration
DB_HOST=localhost
DB_NAME=contraction_db
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# Site Configuration
SITE_URL=http://localhost/contraction/
SITE_NAME=PATIL's Construction & Interior's
SITE_EMAIL=info@patilconstruction.com
SITE_PHONE=+91 XXXXX XXXXX

# Admin Configuration
ADMIN_PIN=7676
ADMIN_EMAIL=admin@patilconstruction.com

# Email Configuration (for contact forms)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@patilconstruction.com
SMTP_FROM_NAME=PATIL's Construction

# File Upload Configuration
UPLOAD_MAX_SIZE=5242880
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,pdf,doc,docx
UPLOAD_PATH=uploads/

# Security Configuration
SESSION_LIFETIME=3600
CSRF_TOKEN_LENGTH=32
PASSWORD_MIN_LENGTH=8

# Development/Production
ENVIRONMENT=development
DEBUG=true
LOG_ERRORS=true

# API Keys (if needed)
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
GOOGLE_MAPS_API_KEY=

# Cache Configuration
CACHE_ENABLED=false
CACHE_LIFETIME=3600

# Backup Configuration
BACKUP_ENABLED=false
BACKUP_PATH=backup/
BACKUP_FREQUENCY=daily
